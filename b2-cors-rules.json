[
  {
    "corsRuleName": "elim-videos-browser-upload",
    "allowedOrigins": [
      "https://www.elimlldm.net",
      "https://elimlldm.net",
      "https://*.vercel.app",
      "http://localhost:3000"
    ],
    "allowedHeaders": [
      "authorization",
      "content-type",
      "x-bz-content-sha1",
      "x-bz-file-name"
    ],
    "allowedOperations": [
      "b2_upload_file",
      "b2_download_file_by_name",
      "b2_download_file_by_id"
    ],
    "exposeHeaders": [
      "x-bz-content-sha1",
      "x-bz-file-name"
    ],
    "maxAgeSeconds": 3600
  }
]
